{erl_opts, [debug_info]}.

{project_plugins, [erlfmt, rebar3_ex_doc]}.

{erlfmt, [write]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {proglang, erlang},
    {main, <<"readme">>},
    {extras, [<<"README.md">>, <<"LICENSE">>]},
    {source_url, <<"https://github.com/Taure/opentelemetry_kura">>}
]}.

{xref_ignores, [opentelemetry_kura]}.

{deps, [
    {telemetry, "~> 1.0"},
    {opentelemetry_api, "~> 1.4"}
]}.

{profiles, [
    {test, [
        {deps, [
            {opentelemetry, "~> 1.5"}
        ]}
    ]}
]}.
